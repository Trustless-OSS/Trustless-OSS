#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Enforce Conventional Commits format on every commit message
# Pattern: type(optional-scope): description
# Examples:
#   feat: add wallet connect page
#   fix(webhook): handle null PR body
#   docs: update README setup steps

commit_msg=$(cat "$1")
pattern="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?: .{1,100}$"

if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "  Required: type(optional-scope): description"
  echo ""
  echo "  Valid types: feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert"
  echo ""
  echo "  Examples:"
  echo "    feat: add stellar wallet connect"
  echo "    fix(webhook): handle null PR body"
  echo "    docs: update README setup"
  echo ""
  echo "  Your message: $commit_msg"
  echo ""
  exit 1
fi
