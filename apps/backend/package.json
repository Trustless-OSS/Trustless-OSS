{
  "name": "@trustless-oss/backend",
  "version": "1.0.0",
  "description": "Trustless-OSS backend — Node.js + TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "tsx src/migrate.ts",
    "proxy": "tsx src/webhook-proxy.ts",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=-1",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@octokit/app": "^14.0.0",
    "@stellar/stellar-sdk": "^12.0.0",
    "@supabase/supabase-js": "^2.0.0",
    "bullmq": "^5.78.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "pg": "^8.20.0",
    "smee-client": "^5.0.0",
    "stellar-sdk": "^13.3.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
