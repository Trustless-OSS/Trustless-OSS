{
  "name": "trustless-oss",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.3+sha512.f2c531b08829d7be7f03c90addc266615f9c5477463e4bf1d275cb263ce9ea57cf0d5599110d94649a9bb3fed9f0b5efcea74a7016b61532a24cb9ad87860c1d",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:backend": "turbo dev --filter=@trustless-oss/backend",
    "dev:frontend": "turbo dev --filter=@trustless-oss/frontend",
    "build": "turbo build",
    "build:backend": "turbo build --filter=@trustless-oss/backend",
    "build:frontend": "turbo build --filter=@trustless-oss/frontend",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "typecheck": "turbo typecheck",
    "fmt": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "fmt:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "validate": "turbo typecheck lint && pnpm fmt:check",
    "clean": "turbo clean && rm -rf .turbo",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2.0.0"
  },
  "lint-staged": {
    "apps/backend/src/**/*.ts": [
      "prettier --write",
      "pnpm --filter @trustless-oss/backend lint:fix"
    ],
    "apps/frontend/**/*.{ts,tsx}": [
      "prettier --write",
      "pnpm --filter @trustless-oss/frontend lint:fix"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "protobufjs": ">=7.5.6",
      "postcss": ">=8.5.10",
      "uuid": ">=11.1.1"
    }
  }
}
