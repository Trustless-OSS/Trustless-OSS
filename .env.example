# Trustless OSS — Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# SHARED (Backend + Frontend)
# ============================================================================

# Node environment: development | production
NODE_ENV=development

# Server port (backend only)
PORT=4000

# ============================================================================
# SUPABASE
# ============================================================================

# Supabase project URL — find at https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co

# Supabase service role key (backend only) — keep secret, never commit
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase anon key (frontend) — safe to expose, use for client-side auth
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# GITHUB APP
# ============================================================================

# GitHub App ID — register at https://github.com/settings/apps
GITHUB_APP_ID=123456

# GitHub App private key (PEM format) — download from GitHub App settings
# Store as one-line string with \n for newlines, or base64 encoded
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...

# Webhook secret — create when registering GitHub App
GITHUB_WEBHOOK_SECRET=your-webhook-secret-here

# GitHub personal access token (bot account) — for posting comments, managing repos
# Required scopes: repo, read:user, user:email
GITHUB_BOT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub App slug (frontend only) — for "Install App" links
# Find at https://github.com/apps/your-app-name
NEXT_PUBLIC_GITHUB_APP_SLUG=your-app-slug

# ============================================================================
# STELLAR & BLOCKCHAIN
# ============================================================================

# Stellar network: testnet | mainnet
STELLAR_NETWORK=testnet

# Platform wallet (releaseSigner for escrow) — secret key
# This is the signer that auto-approves and releases escrow payments
PLATFORM_STELLAR_SECRET_KEY=SCZG...

# Platform wallet public key (for escrow roles)
PLATFORM_STELLAR_PUBLIC_KEY=GCXG...

# ============================================================================
# TRUSTLESS WORK API
# ============================================================================

# Trustless Work API key — contact Trustless Work team
TRUSTLESS_WORK_API_KEY=your-api-key-here

# Trustless Work API base URL
TRUSTLESS_WORK_BASE_URL=https://dev.api.trustlesswork.com

# ============================================================================
# APPLICATION URLS
# ============================================================================

# App URL (backend) — where your app is hosted, used for GitHub webhook redirect links
APP_URL=http://localhost:3000

# Frontend URL (for linking from backend)
FRONTEND_URL=http://localhost:3000

# Webhook URL (backend, optional) — override webhook endpoint
# Useful for testing with ngrok: https://xxxx.ngrok.io/api/webhooks/github
WEBHOOK_URL=http://localhost:4000/api/webhooks/github

# Backend URL (frontend) — where API requests go
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# ============================================================================
# DATABASE (optional, if using direct PostgreSQL)
# ============================================================================

# PostgreSQL connection string (if not using Supabase-hosted auth)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/trustless_oss
