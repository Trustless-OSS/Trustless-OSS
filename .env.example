# Trustless OSS — Environment Variables

# Shared
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Frontend
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# GitHub App
GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_BOT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub Frontend
NEXT_PUBLIC_GITHUB_APP_SLUG=your-app-slug

# Stellar
STELLAR_NETWORK=testnet
PLATFORM_STELLAR_SECRET_KEY=SCZG...
PLATFORM_STELLAR_PUBLIC_KEY=GCXG...

# Trustless Work API
TRUSTLESS_WORK_API_KEY=your-api-key-here
TRUSTLESS_WORK_BASE_URL=https://dev.api.trustlesswork.com

# Server
PORT=4000
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000
WEBHOOK_URL=http://localhost:4000/api/webhooks/github

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/trustless_oss
